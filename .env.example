# Copy to .env.local for local development.

# Auth.js — generate with: npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET=

# Google OAuth client (Google Cloud Console → APIs & Services → Credentials)
# Authorized redirect URIs:
#   http://localhost:3000/api/auth/callback/google
#   https://<your-app>.vercel.app/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Comma-separated Google account emails allowed to sign in
ALLOWED_EMAILS=ollie.bondan@gmail.com,aisha.bondan@gmail.com,esti.bondan@gmail.com

# Set automatically by Vercel when a Blob store is connected.
# Leave empty locally — local dev falls back to data/records.csv on disk.
BLOB_READ_WRITE_TOKEN=

# Local dev only: set to 1 to skip Google login entirely (never works in production)
DEV_NO_AUTH=
