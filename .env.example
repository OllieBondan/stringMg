# Copy to .env.local for local development.

# Auth.js — generate with: npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET=

# Google OAuth client (Google Cloud Console → APIs & Services → Credentials)
# Authorized redirect URIs:
#   http://localhost:3000/api/auth/callback/google
#   https://<your-app>.vercel.app/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Comma-separated Google account emails allowed to sign in
ALLOWED_EMAILS=ollie.bondan@gmail.com,aisha.bondan@gmail.com,esti.bondan@gmail.com,alyssatasya@gmail.com,titon@yonex.ch

# Neon Postgres connection string — set automatically by Vercel when the Neon
# database is connected (Storage tab). For local dev copy it from the Neon
# quickstart in the Vercel dashboard. THIS IS A SECRET — .env.local only.
DATABASE_URL=

# Legacy: only needed to run the one-time /api/admin/import-csv migration
# from the old Blob CSV. Can be removed once the import is done.
BLOB_READ_WRITE_TOKEN=

# Comma-separated emails allowed to confirm the final "payment received by
# Tasya" step (defaults to alyssatasya@gmail.com if unset)
TASYA_EMAILS=

# Local dev only: set to 1 to skip Google login entirely (never works in production)
DEV_NO_AUTH=
